# Frontend URL
FRONTEND_URL=https://aquawash.pages.dev/

# API URL
API_URL=http://localhost:8000

# Google OAuth client ID (debe ser igual a VITE_GOOGLE_CLIENT_ID del frontend)
GOOGLE_CLIENT_ID=TU_CLIENT_ID_DE_GOOGLE

# Headless mode (true/false)
HEADLESS=false

# Test user credentials (opcional, para pruebas de login)
TEST_EMAIL=demo@aquawash.com
TEST_PASSWORD=demo123456
